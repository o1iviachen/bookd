rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Public read collections (synced by Cloud Functions) ───
    // These are read-only for clients; only Cloud Functions (admin SDK) can write.

    match /matches/{matchId} {
      allow read: if true;
      allow write: if false;
      // Authenticated users can update only MOTM votes and rating aggregates
      allow update: if request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['motmVotes', 'ratingSum', 'ratingCount', 'reviewCount', 'ratingBuckets', 'discussionCount']);

      // MOTM votes subcollection — one doc per user
      match /motmVotes/{voteId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == voteId;
      }
    }

    match /matchDetails/{matchId} {
      allow read: if true;
      allow write: if false;
    }

    match /standings/{standingId} {
      allow read: if true;
      allow write: if false;
    }

    match /competitions/{competitionId} {
      allow read: if true;
      allow write: if false;
    }

    match /teams/{teamId} {
      allow read: if true;
      allow write: if false;
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if false;
    }

    match /leagues/{leagueCode} {
      allow read: if true;
      allow write: if false;
    }

    // ─── User profiles ───
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      // Owner can update anything; other users can only modify follow/block arrays
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followers', 'following', 'blockedBy'])
      );
    }

    // ─── Reviews ───
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;

      // Votes subcollection
      match /votes/{voteId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // ─── Comments ───
    match /comments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      // Owner can update/delete anything; other users can only modify likedBy + likes
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likes'])
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // ─── Match Discussions ───
    match /matchDiscussions/{messageId} {
      allow read: if true;
      allow create: if request.auth != null;
      // Owner can update/delete anything; other users can only modify likedBy + likes
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likes'])
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // ─── List Comments ───
    match /listComments/{commentId} {
      allow read: if true;
      allow create: if request.auth != null;
      // Owner can update/delete anything; other users can only modify likedBy + likes
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likes'])
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // ─── Lists ───
    match /lists/{listId} {
      allow read: if true;
      allow create: if request.auth != null;
      // Owner can update/delete anything; other users can only modify likedBy + likes
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.userId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy', 'likes'])
      );
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // ─── Pre-computed aggregates (written by Cloud Functions only) ───
    match /aggregates/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ─── Reports (written by Cloud Function admin SDK only) ───
    match /reports/{reportId} {
      allow read, write: if false;
    }

    // ─── Notifications ───
    match /notifications/{notifId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.recipientId;
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.recipientId;
    }
  }
}
