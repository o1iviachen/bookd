{
  "name": "bookd-functions",
  "version": "1.0.0",
  "description": "Cloud Functions for bookd — syncs match data from API-Football to Firestore",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
