  },
  "engines": {
    "node": "22"
  },
  "dependencies": {
    "@google-cloud/vision": "^5.3.4",
    "axios": "^1.7.0",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  },
  "private": true
}
