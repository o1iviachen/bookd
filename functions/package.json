    "firebase-functions": "^5.0.0",
    "nodemailer": "^8.0.1"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.4.0"
  },
  "private": true
