{
  "expo": {
    "name": "Bookd",
    "slug": "bookd",
    "scheme": "bookd",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/bookd-logo.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-screen.png",
      "resizeMode": "cover",
      "backgroundColor": "#14181c"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bookd-app",
      "associatedDomains": ["applinks:bookd-app.com"],
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.bookd.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#14181c"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow bookd to access your photos for profile pictures and reviews.",
          "cameraPermission": "Allow bookd to use your camera for profile pictures and reviews.",
          "microphonePermission": "Allow bookd to access the microphone for video recordings."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#00e054"
        }
      ],
      "expo-web-browser",
      "expo-apple-authentication",
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "e5b69e83-26d5-4139-8708-2bcac062ea63"
      }
    }
  }
}
