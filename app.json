{
  "expo": {
    "name": "bookd",
    "slug": "bookd",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#14181c"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bookd.app"
    },
    "android": {
      "package": "com.bookd.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#14181c"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow bookd to access your photos for profile pictures and reviews.",
          "cameraPermission": "Allow bookd to use your camera for profile pictures and reviews.",
          "microphonePermission": "Allow bookd to access the microphone for video recordings."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#00e054"
        }
      ]
    ]
  }
}
